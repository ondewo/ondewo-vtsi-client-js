{
  "name": "@ondewo/ondewo-vtsi-client-js",
  "version": "8.2.0",
  "description": "ONDEWO Voip Telephone System Integration (VTSI) Client library for Js",
  "author": "ONDEWO GmbH",
  "homepage": "https://ondewo.com",
  "license": "Apache-2.0",
  "keywords": [
    "ondewo",
    "vtsi",
    "api",
    "client",
    "js",
    "grpc"
  ],
  "repository": {
    "type": "git",
    "directory": "https://github.com/ondewo/ondewo-vtsi-client-js.git"
  },
  "scripts": {
    "test:auth": "c8 --check-coverage --lines 100 --branches 100 --functions 100 --include auth/offlineTokenProvider.js --exclude '**/*.spec.js' --reporter text node --test auth/offlineTokenProvider.spec.js",
    "test:examples": "node --test example/client.spec.js",
    "test": "npm run test:auth && npm run test:examples"
  },
  "dependencies": {
    "google-protobuf": "^3.21.4",
    "grpc-web": "^1.5.0",
    "terser-webpack-plugin": "^5.3.14",
    "undici": "^6.27.0",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "global": "^4.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.4",
    "dotenv": "^16.4.5"
  }
}
